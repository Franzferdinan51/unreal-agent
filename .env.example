# Unreal Agent — env example
# Copy to .env or .env.local and fill in your keys.

# Primary cloud provider (MiniMax)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=minimax-portal/MiniMax-M2.7

# Fallback provider (Grok / xAI)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.3

# Free fallback (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# OpenAI direct
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1

# Local OpenAI-compatible runtime (LM Studio)
LMSTUDIO_API_KEY=
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=local-model

# Local OpenAI-compatible runtime (Ollama)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.1

# Optional: pin a UE project path so the agent always knows
# UE_PROJECT=/path/to/MyGame.uproject

# Optional: override the UE MCP server URL
# UE_MCP_URL=http://127.0.0.1:8000/mcp
